</form>
<script>
    require(["jquery"], function ($) {
        $(document).ready(function () {
            $('.syncMetaProperties').click(function () {
                var customurl = '<?= $block->escapeHtml($syncMetaUrl); ?>';
                $.ajax({
                    url: customurl,
                    type: 'POST',
                    showLoader: true,
                    async: true,
                    loaderArea: true,
                    timeout: 300000,
                    complete: function (response) {
                        location.reload(true);
                    }
                });
            });
        });
    });
</script>